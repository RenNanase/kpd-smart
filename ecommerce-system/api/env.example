# Copy this file to: ecommerce-system/.env
# (The api loads .env from ecommerce-system/ when you run npm run dev -w api)

# PostgreSQL — replace USER, PASSWORD, HOST, PORT with yours.
# Database name: kpd-smart (URL-encode special characters in USER or PASSWORD)
#
# Examples:
#   postgresql://postgres:secret@localhost:5432/kpd-smart
#   postgresql://myuser:myp%40ss@127.0.0.1:5432/kpd-smart
#
# No password (common for local "trust" auth) — omit :password entirely:
#   postgresql://postgres@localhost:5432/kpd-smart
# Or empty password (some clients prefer this):
#   postgresql://postgres:@localhost:5432/kpd-smart

DATABASE_URL=postgresql://postgres@localhost:5432/kpd-smart

# Optional — default 3000
# PORT=3000

# Set to 1 to skip running SQL migrations on API startup (e.g. production with external migrator)
# SKIP_DB_MIGRATE=1
